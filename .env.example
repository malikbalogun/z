# Legacy: this project now uses config.json + SQLite (see config.json.example).
# Keys and bot toggles are edited in the Admin UI (/admin). Optional: merge OS env
# into Settings if the same variable names are set (see Settings.from_kv merge_os_environ).

# ── Legacy .env (optional) ───────────────────────────────────────
POLYMARKET_PRIVATE_KEY=
# Proxy / funder address shown on Polymarket profile (also used for USDC balance read)
WALLET_ADDRESS=
# 0 = EOA signs directly; 1 = email/Magic proxy (set funder = WALLET_ADDRESS)
POLYMARKET_SIGNATURE_TYPE=0

# ── Safety ────────────────────────────────────────────────────────
DRY_RUN=true
# UI: dashboard = browser only  |  terminal = Rich TUI in SSH  |  both = web + TUI
# Override once: python main.py --ui terminal
UI_MODE=both
# Bind dashboard (127.0.0.1 recommended; use 0.0.0.0 on VPS + firewall)
HOST=127.0.0.1
PORT=5002
# If set, POST /api/kill, /api/scan, and /api/reconcile require: Authorization: Bearer <secret>
DASHBOARD_SECRET=

# ── Sizing & scan ───────────────────────────────────────────────
DEFAULT_BET_SIZE_USD=5
MIN_BET_SIZE_USD=1
MAX_BET_SIZE_USD=25
SCAN_INTERVAL_SECONDS=120
MAX_TRADES_PER_CYCLE=1
MIN_CLOB_LIQUIDITY_USD=500
MIN_GAMMA_VOLUME=1000

# ── Execution: strict limit + TTL, then cancel (no surprise market orders) ──
STRICT_EXECUTION=true
ORDER_TTL_SECONDS=45
ORDER_POLL_SECONDS=2.0
ALLOW_MARKET_FALLBACK=false
# Emergency: skip trading cycles (GET /api/state still works)
TRADING_PAUSED=false
# Extra USDC required on top of each intent size (buffer)
BALANCE_BUFFER_USD=0
# Crypto: reject if CEX dispersion could not be computed (stricter)
CEX_REQUIRE_DISPERSION=false

# ── Observability & reconciliation ─────────────────────────────
# One-line JSON events prefixed with SLOG (grep-friendly)
STRUCTURED_LOG=true
# After each cycle: pull open orders + refresh last N trade rows from CLOB
RECONCILE_ENABLED=true
RECONCILE_HISTORY_DEPTH=15
RECONCILE_POLL_SLEEP_S=0.06
OPEN_ORDERS_DISPLAY_LIMIT=40

# ── Agents ──────────────────────────────────────────────────────
AGENT_VALUE=true
AGENT_COPY=false
# Comma-separated 0x addresses to mirror (requires AGENT_COPY=true)
COPY_WATCH_WALLETS=

# ── Multi-CEX gate (crypto categories only) ───────────────────
CEX_GATE_CRYPTO=true
MAX_CEX_DISPERSION_BPS=25

# ── Category toggles (false = no trades in that bucket) ─────────
ENABLE_CRYPTO_SHORT=true
ENABLE_CRYPTO_OTHER=true
ENABLE_SPORTS=true
ENABLE_POLITICS=true
ENABLE_MACRO=true
ENABLE_WEATHER=true
ENABLE_SCIENCE_TECH=true
ENABLE_ENTERTAINMENT=true
ENABLE_GEOPOLITICS=true
ENABLE_OTHER=true
