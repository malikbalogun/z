{
  "name": "polymarket_real_bot",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "postCreateCommand": "chmod +x scripts/*.sh 2>/dev/null; bash scripts/setup_workspace.sh",
  "forwardPorts": [5002],
  "portsAttributes": {
    "5002": {
      "label": "Bot dashboard",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      },
      "extensions": ["ms-python.python"]
    }
  }
}
